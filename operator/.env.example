# Network RPC URLs
RPC_TEST=http://127.0.0.1:1234/rpc/v1
RPC_CALIBNET=https://api.calibration.node.glif.io/rpc/v1
RPC_MAINNET=https://api.node.glif.io/rpc/v1

# Deployment keys (one per network)
PRIVATE_KEY_TEST=<your_private_key>
PRIVATE_KEY_CALIBNET=<your_private_key>
PRIVATE_KEY_MAINNET=<your_private_key>

# Devnet external addresses (required by script/Deploy.s.sol mapped in justfile)
FILECOIN_PAY_TEST=<filecoin_pay_devnet>
TOKEN_TEST=<payment_token_devnet>

# Calibnet external addresses (required by script/Deploy.s.sol mapped in justfile)
FILECOIN_PAY_CALIBNET=<filecoin_pay_calibnet>
TOKEN_CALIBNET=<payment_token_calibnet>

# Mainnet external addresses (required by script/Deploy.s.sol mapped in justfile)
FILECOIN_PAY_MAINNET=<filecoin_pay_mainnet>
TOKEN_MAINNET=<payment_token_mainnet>

# Upgrade script (script/Upgrade.s.sol)
UPGRADE_CONTRACT_NAME=Operator
UPGRADE_CALLDATA=0x
# For an OperatorFactory upgrade that must initialize config on an older proxy:
# UPGRADE_CALLDATA=<cast calldata "setFilecoinPayConfig(address,address)" "$FILECOIN_PAY_MAINNET" "$TOKEN_MAINNET">

# Blockscout verification
# CONFIRM_MAINNET=yes is required by script/verify-blockscout.sh verify 314.
